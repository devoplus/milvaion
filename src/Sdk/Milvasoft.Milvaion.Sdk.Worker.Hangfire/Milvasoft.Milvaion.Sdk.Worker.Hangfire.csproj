<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>disable</Nullable>
		<PlatformTarget>AnyCPU</PlatformTarget>
		<IsPackable>true</IsPackable>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Hangfire.Core" Version="1.*" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
		<PackageReference Include="RabbitMQ.Client" Version="7.*" />
		<PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.*" />
		<PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.*" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Milvasoft.Milvaion.Sdk.Worker\Milvasoft.Milvaion.Sdk.Worker.csproj" />
		<ProjectReference Include="..\Milvasoft.Milvaion.Sdk\Milvasoft.Milvaion.Sdk.csproj" />
	</ItemGroup>

	<ItemGroup>
		<None Include="logo.png" Pack="true" PackagePath="\" />
		<None Include="packagereadme.md" Pack="true" PackagePath="\" />
	</ItemGroup>

	<PropertyGroup>
		<PackageVersion>10.0.16</PackageVersion>
		<Authors>Milvasoft Corporation</Authors>
		<Copyright>Milvasoft Yazılım Bilişim Araştırma Geliştirme Danışmanlık Sanayi ve Ticaret Ltd.Şti.</Copyright>
		<RepositoryUrl>https://github.com/Milvasoft/milvaion-api</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageProjectUrl>https://github.com/Milvasoft/milvaion-api</PackageProjectUrl>
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>

		<PackageId>Milvasoft.Milvaion.Sdk.Worker.Hangfire</PackageId>
		<Product>Milvasoft.Milvaion.Sdk.Worker.Hangfire</Product>
		<Description>Hangfire integration for Milvaion Worker SDK.</Description>
		<PackageTags>schedule,recurring,worker,distributed,hangfire</PackageTags>
		<PackageIcon>logo.png</PackageIcon>
		<PackageReadmeFile>packagereadme.md</PackageReadmeFile>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
	</PropertyGroup>

</Project>
