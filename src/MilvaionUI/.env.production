# Production environment — values are baked into the JS bundle at build time.
# VITE_API_BASE_URL and VITE_API_URL are intentionally empty so the app uses
# relative paths and picks up whatever origin/basePath it is served from.
VITE_API_BASE_URL=
VITE_API_URL=
VITE_APP_NAME=Milvaion Scheduler
VITE_APP_VERSION=1.0.0
# Override in your CI/CD or docker-compose build args if you change the base path.
VITE_BASE_PATH=/milvaion
